# === Environment & Secrets (CRITICAL SECURITY) ===
# Nunca suba arquivos que contenham tokens, chaves de API ou segredos
.env*
!.env.example
secrets.json
credentials.json
tokens.json
*.key
*.pem
cert.crt
*.pfx
*.p12
*.gpg
*.asc
config.json
settings.json
auth.json

# === Project Specific Data (Security) ===
# Arquivos de dados que podem conter informações sensíveis de contatos ou reuniões
reunioes.json
*.json
# Se quiser permitir algum JSON específico, use !nome_do_arquivo.json abaixo
!package.json
!composer.json

